# Application Configuration
VITE_APP_NAME=nuwault-web
VITE_APP_URL='https://nuwault.com'

VITE_APP_TITLE='Secure & Deterministic Passwords'
VITE_APP_DESCRIPTION='Nuwault is a privacy-first, offline password generator that creates secure and deterministic passwords from your keywords. No cloud, no storage - just pure cryptographic logic.'
VITE_APP_KEYWORDS='nuwault, deterministic password generator, encrypted password tool, offline password manager, secure credentials, e2ee password generator, privacy-first tool, seed phrase security, nuwax, nuwa x, cryptographic identity, zero-knowledge password, developer password tool, reproducible passwords, secure vault'
VITE_APP_AUTHOR='NuwaX'

VITE_APP_KEY=your-unique-production-salt-key-here

# Application Environment (development, production)
VITE_NODE_ENV=development

# Feature Flags
VITE_ENABLE_DEBUG_MODE=true

# Character Sets for Password Generation
VITE_CHARSET_UPPERCASE=ABCDEFGHIJKLMNOPQRSTUVWXYZ
VITE_CHARSET_LOWERCASE=abcdefghijklmnopqrstuvwxyz
VITE_CHARSET_NUMBERS=0123456789
VITE_CHARSET_SYMBOLS='!@#$%^&*()_+-=[]{}|;:,.<>?'

# Symbol Subcategory Character Sets
VITE_SYMBOL_LOGOGRAMS='#$%&@^`~'
VITE_SYMBOL_MATH='<>*+!?='
VITE_SYMBOL_BRACES='{[()]}'
VITE_SYMBOL_DASHES='\/|_-'
VITE_SYMBOL_PUNCTUATION='.,:;'
VITE_SYMBOL_QUOTES="\"'"
VITE_SYMBOL_EXTENDED='┬Į┬®├Ä├Ö├Ą├ś├Ü┬¬┬▓├Į├»┬║┬Ę├ü┬ż├”├¬┬▒├Ī├¼├¤├¦├Æ├ż┬╣├«├ó┬ź┬»├ē├▓├│├ö├ć┬Š├é├£┬╝├ź├½├╝┬Ī┬╗├É├®├Ę'

# Look-alike Characters (excluded when "Exclude look-alike" is enabled)
VITE_LOOK_ALIKE_CHARS=01lIO|.B9G6

# Default Symbol Category Selection (true=on, false=off)
VITE_DEFAULT_SYMBOL_LOGOGRAMS=true
VITE_DEFAULT_SYMBOL_MATH=true
VITE_DEFAULT_SYMBOL_BRACES=true
VITE_DEFAULT_SYMBOL_DASHES=true
VITE_DEFAULT_SYMBOL_PUNCTUATION=true
VITE_DEFAULT_SYMBOL_QUOTES=false
VITE_DEFAULT_SYMBOL_EXTENDED=false

# Default Password Options
VITE_DEFAULT_INCLUDE_UPPERCASE=true
VITE_DEFAULT_INCLUDE_LOWERCASE=true
VITE_DEFAULT_INCLUDE_NUMBERS=true
VITE_DEFAULT_INCLUDE_SYMBOLS=true

# Security Settings
VITE_MIN_PASSWORD_LENGTH=8
VITE_MAX_PASSWORD_LENGTH=128
VITE_DEFAULT_PASSWORD_LENGTH=16

# Hash Algorithm Configuration
VITE_HASH_ALGORITHM=SHA-512
VITE_HASH_ITERATIONS=1000

# UI Configuration
VITE_DEFAULT_THEME=system

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_PWA_SHORT_NAME=${VITE_APP_NAME}
VITE_PWA_THEME_COLOR=#2ebba8

# Social Links
VITE_SOCIAL_GITHUB=https://github.com/nuwax-io/nuwault-web

# Contact Information
VITE_CONTACT_MAIL=support@nuwault.com

# Keyword Management Default Settings
VITE_DEFAULT_MASK_KEYWORDS=true
VITE_DEFAULT_AUTO_GENERATE_PASSWORD=true
VITE_DEFAULT_MASK_PASSWORD=true
VITE_DEFAULT_EXCLUDE_LOOK_ALIKE=false