{
  "name": "@nuwax-io/nuwault-web",
  "version": "1.3.0",
  "description": "Advanced keyword-based password generator with client-side security, privacy focus and PWA support",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run generate-sw && vite",
    "build": "npm run generate-sw && vite build",
    "build:pwa": "npm run generate-icons && npm run generate-sw && npm run build",
    "preview": "vite preview",
    "serve": "vite preview --host",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-sw": "node scripts/generate-sw.js",
    "pwa:install-deps": "npm install sharp --save-dev",
    "pwa:setup": "npm run pwa:install-deps && npm run generate-icons && npm run generate-sw",
    "clean": "rm -rf dist",
    "validate": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "password",
    "generator",
    "security",
    "privacy",
    "pwa",
    "progressive-web-app",
    "client-side",
    "offline",
    "crypto",
    "web-crypto-api",
    "tailwindcss",
    "vite",
    "javascript",
    "password-strength",
    "secure-generation",
    "keyword-based",
    "deterministic",
    "no-server",
    "privacy-first"
  ],
  "author": "NuwaX",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuwax-io/nuwault-web.git"
  },
  "bugs": {
    "url": "https://github.com/nuwax-io/nuwault-web/issues"
  },
  "homepage": "https://nuwault.com",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "sharp": "^0.34.2",
    "terser": "^5.43.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@nuwax-io/nuwault-core": "^1.0.1",
    "@tailwindcss/vite": "^4.1.11",
    "i18next": "^26.2.0",
    "tailwindcss": "^4.1.11"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not op_mini all"
  ]
}
